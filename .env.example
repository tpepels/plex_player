# Copy this file to .env and fill in your real values.
# You can also set PLEXLCD_ENV=/path/to/.env to use a custom location.

PLEX_SERVER=http://<PLEX_SERVER_IP>:32400
PLEX_TOKEN=<YOUR_PLEX_TOKEN>
PLAYER_NAME=<YOUR_EXACT_PLAYER_NAME>

LATITUDE=<YOUR_LATITUDE>
LONGITUDE=<YOUR_LONGITUDE>
TIMEZONE=<YOUR_TIMEZONE>

FB_DEVICE=/dev/fb1
WIDTH=320
HEIGHT=240
DISPLAY_X_SHIFT=0
BUTTONS_ENABLED=1
BUTTON_PLAY_PAUSE_PIN=23
BUTTON_STOP_PIN=24
BUTTON_NEXT_PIN=25
BUTTON_LABEL_PLAY_Y_PERCENT=20
BUTTON_LABEL_STOP_Y_PERCENT=40
BUTTON_LABEL_NEXT_Y_PERCENT=60
POLL_SECONDS=3
WEATHER_REFRESH_SECONDS=900
