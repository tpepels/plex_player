# Copy this file to .env and fill in your real values.
# You can also set PLEXLCD_ENV=/path/to/.env to use a custom location.

PLEX_SERVER=http://<PLEX_SERVER_IP>:32400
PLEX_TOKEN=<YOUR_PLEX_TOKEN>
PLAYER_NAME=<YOUR_EXACT_PLAYER_NAME>

LATITUDE=<YOUR_LATITUDE>
LONGITUDE=<YOUR_LONGITUDE>
TIMEZONE=<YOUR_TIMEZONE>

FB_DEVICE=/dev/fb1
WIDTH=320
HEIGHT=240
POLL_SECONDS=3
WEATHER_REFRESH_SECONDS=900
